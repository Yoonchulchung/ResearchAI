# ── Cloud AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# ── Web Search (하나 이상 설정하면 파이프라인 활성화) ─────────
# 설정된 모든 검색 엔진을 병렬 실행 후 결과를 합칩니다.
# 미설정 시: 각 Cloud Model 내장 검색 사용 (기존 방식)

# Tavily  - AI 최적화, 무료 1000회/월  | https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key
TAVILY_SEARCH_DEPTH=basic   # basic | advanced

# Serper  - Google 검색, 무료 2500회   | https://serper.dev
SERPER_API_KEY=your_serper_api_key

# 네이버  - 한국어 콘텐츠 특화          | https://developers.naver.com
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Brave   - 독립 검색, 무료 2000회/월  | https://api.search.brave.com
BRAVE_API_KEY=your_brave_api_key

# ── Local AI Filtering (Ollama) ────────────────────────────
# 검색 파이프라인 활성화 시 자동 적용 (미실행이면 graceful skip)
# 설치: https://ollama.com → ollama run llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b   # 권장: llama3.2:3b / qwen2.5:7b / gemma2:9b
