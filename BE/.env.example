# ── 회원가입 초대 코드 ──────────────────────────────────────
# 설정 시 이 코드를 입력해야만 회원가입 가능 (미설정이면 누구나 가입 가능)
REGISTER_CODE=your_invite_code

# ── Cloudflare Turnstile (봇 방어) ────────────────────────
# https://dash.cloudflare.com → Turnstile → 사이트 추가 → Secret Key
# 미설정 시 로컬 개발 환경에서는 검증 건너뜀
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Cloud AI ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# ── Local AI Filtering (Ollama) ────────────────────────────
# 검색 파이프라인 활성화 시 자동 적용 (미실행이면 graceful skip)
# 설치: https://ollama.com → ollama run llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b   # 권장: llama3.2:3b / qwen2.5:7b / gemma2:9b
