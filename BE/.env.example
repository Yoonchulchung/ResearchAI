# ── 회원가입 초대 코드 ──────────────────────────────────────
# 설정 시 이 코드를 입력해야만 회원가입 가능 (미설정이면 누구나 가입 가능)
REGISTER_CODE=your_invite_code

# ── Cloudflare Turnstile (봇 방어) ────────────────────────
# https://dash.cloudflare.com → Turnstile → 사이트 추가 → Secret Key
# 미설정 시 로컬 개발 환경에서는 검증 건너뜀
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Cloud AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# ── Web Search (하나 이상 설정하면 파이프라인 활성화) ─────────
# 설정된 모든 검색 엔진을 병렬 실행 후 결과를 합칩니다.
# 미설정 시: 각 Cloud Model 내장 검색 사용 (기존 방식)

# Tavily  - AI 최적화, 무료 1000회/월  | https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key
TAVILY_SEARCH_DEPTH=basic   # basic | advanced

# Serper  - Google 검색, 무료 2500회   | https://serper.dev
SERPER_API_KEY=your_serper_api_key

# 네이버  - 한국어 콘텐츠 특화          | https://developers.naver.com
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Brave   - 독립 검색, 무료 2000회/월  | https://api.search.brave.com
BRAVE_API_KEY=your_brave_api_key

# ── Gmail OAuth ────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials에서 발급
# Gmail API 활성화 필요: https://console.cloud.google.com/apis/library
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# ── Local AI Filtering (Ollama) ────────────────────────────
# 검색 파이프라인 활성화 시 자동 적용 (미실행이면 graceful skip)
# 설치: https://ollama.com → ollama run llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b   # 권장: llama3.2:3b / qwen2.5:7b / gemma2:9b
