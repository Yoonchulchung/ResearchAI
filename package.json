{
  "name": "research-ai-desktop",
  "version": "1.0.0",
  "description": "ResearchAI macOS Desktop App",
  "main": "electron/dist/main.js",
  "private": true,
  "scripts": {
    "electron:compile": "tsc -p electron/tsconfig.json",
    "build:be": "cd BE && pnpm run build",
    "build:fe": "cd FE && npm run build",
    "build": "npm run build:be && npm run build:fe && npm run electron:compile",
    "dev": "npm run build:be && npm run electron:compile && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  }
}
